{
  "manifest_version": 3,
  "name": "Cockpit Bridge",
  "version": "1.0.1",
  "description": "Cockpit 浏览器气泡的链接拦截与导航通信桥",
  "permissions": ["alarms", "storage", "declarativeNetRequest", "cookies", "webRequest", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "remove_frame_headers",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
